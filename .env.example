# Single source of truth for both docker-compose.yml (${VAR} substitution)
# and the app containers (injected via env_file). Copy to .env and adjust
# if needed — these defaults work out of the box.

# Postgres (shared credentials; each service still gets its own database container)
DB_USER=postgres
DB_PASS=postgres
DB_NAME=postgres
DB_PORT=5432

BET_MAKER_DB_HOST=bet_maker_db
BET_MAKER_DB_HOST_PORT=5432

LINE_PROVIDER_DB_HOST=line_provider_db
LINE_PROVIDER_DB_HOST_PORT=5433

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=rabbitmq
RABBITMQ_MANAGEMENT_PORT=15672

# RabbitMQ exchange/queue names (shared naming contract between services)
EXCHANGE_NAME=default_exchange
EVENT_UPDATE_QUEUE_NAME=event_updates_queue
REQUEST_QUEUE_NAME=bet_request_queue

# Redis (used by bet-maker for response caching)
REDIS_HOST=redis
REDIS_PORT=6379

# Host-published app ports
BET_MAKER_PORT=8000
LINE_PROVIDER_PORT=8001
